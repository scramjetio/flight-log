---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="FlightLog: Automated Changelog" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- OpenGraph Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content="FlightLog: Automated Changelog" />
		<meta property="og:image" content="https://raw.githubusercontent.com/scramjetio/flight-log/main/.github/assets/hero.png" />
		<meta property="twitter:card" content="summary_large_image" />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0A0A0A] text-[#EDEDED] font-sans antialiased selection:bg-blue-500/30">
		<div class="relative min-h-screen flex flex-col items-center pt-24 pb-32">
			<!-- Background Glow -->
			<div class="absolute top-0 w-full h-[500px] bg-gradient-to-b from-blue-900/20 to-transparent pointer-events-none -z-10"></div>
			
			<header class="w-full max-w-3xl px-6 mb-20 text-center">
				<h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Changelog</h1>
				<p class="text-gray-400 text-lg">New updates and improvements to our platform.</p>
			</header>

			<main class="w-full max-w-3xl px-6">
				<slot />
			</main>
		</div>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
	}
	html {
		scroll-behavior: smooth;
	}
</style>
